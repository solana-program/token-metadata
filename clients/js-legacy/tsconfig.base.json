{
    "include": [],
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "lib": ["ES2020", "DOM"],
        "types": ["node"],
        "esModuleInterop": true,
        "isolatedModules": true,
        "noEmitOnError": true,
        "resolveJsonModule": true,
        "strict": true,
        "stripInternal": true
    }
}
